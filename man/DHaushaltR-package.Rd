\item \link{hf_labels_short} — Hauptfunktion codes → shortened plot labels
\item \link{of_labels} — Oberfunktion codes "01"–"89" → official labels
\item \link{gruppe_labels} — 3-digit Gruppe codes → spending-type labels
\item \link{texan_keywords} — named regex vector for TexAn text analysis
}
